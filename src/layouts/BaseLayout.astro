---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Raven - Self-hosted server monitoring & centralized logging",
  description = "A lightweight, self-hostable server monitoring and centralized logging tool. One agent. One server. Everything in one place.",
  ogImage = "/og.png",
} = Astro.props;

const canonicalBase = Astro.site ?? Astro.url;
const canonicalURL = new URL(Astro.url.pathname, canonicalBase);
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/raven-icon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <slot />
  </body>
</html>
